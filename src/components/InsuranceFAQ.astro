---
// ============================================================================
// INTERACTIVE INSURANCE FAQ ACCORDION (src/components/InsuranceFAQ.astro)
// ============================================================================

import { insuranceFaqTranslations } from '../utils/i18n.js';

interface Props {
  lang?: 'en' | 'bn';
}

const { lang = 'en' } = Astro.props;
const t = insuranceFaqTranslations[lang] || insuranceFaqTranslations.en;
---

<section class="faq-section">
  <div class="faq-header">
    <h2>{t.sectionTitle}</h2>
    <p>{t.sectionSubheading}</p>
  </div>

  <div class="faq-accordion">
    {t.faqs.map((item, index) => (
      <details class="faq-item" data-index={index}>
        <summary class="faq-question">
          <span>{item.question}</span>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <div class="faq-answer">
          <p>{item.answer}</p>
        </div>
      </details>
    ))}
  </div>
</section>

<!-- INTERACTIVE ACCORDION SCRIPT -->
<script>
  // Ensure only one FAQ item stays open at a time (Classic Accordion Behavior)
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll<HTMLDetailsElement>('.faq-item');

    faqItems.forEach((item) => {
      item.addEventListener('toggle', () => {
        if (item.open) {
          faqItems.forEach((otherItem) => {
            if (otherItem !== item) {
              otherItem.open = false;
            }
          });
        }
      });
    });
  });
</script>

<style>
  /* SECTION CONTAINER STYLING */
  .faq-section {
    padding: 3rem 1rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .faq-header h2 {
    font-size: 2rem;
    color: #0b3d91;
    margin-bottom: 0.5rem;
  }

  .faq-header p {
    color: #555;
    font-size: 1rem;
  }

  /* ACCORDION CARD STYLING */
  .faq-accordion {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .faq-item[open] {
    border-color: #0b3d91;
    box-shadow: 0 4px 12px rgba(11, 61, 145, 0.08);
  }

  /* QUESTION / SUMMARY BAR */
  .faq-question {
    list-style: none;
    padding: 1.2rem 1.5rem;
    font-weight: 600;
    font-size: 1.05rem;
    color: #0b3d91;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
  }

  /* Hide default WebKit arrow */
  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question:hover {
    background-color: #f8fafd;
  }

  /* ROTATING PLUS/MINUS ICON */
  .faq-icon {
    font-size: 1.4rem;
    font-weight: 400;
    color: #0b3d91;
    transition: transform 0.3s ease;
    line-height: 1;
    margin-left: 1rem;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg); /* Turns '+' into '×' when opened */
  }

  /* ANSWER CONTENT BOX */
  .faq-answer {
    padding: 0 1.5rem 1.2rem 1.5rem;
    color: #444;
    line-height: 1.6;
    font-size: 0.98rem;
    border-top: 1px solid #f0f0f0;
  }

  .faq-answer p {
    margin: 0.8rem 0 0 0;
  }
</style>