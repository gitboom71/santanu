---
// src/components/Header.astro

const navItems = [
    { name: "Home", url: "/" },
    { name: "About", url: "/about" },
    { name: "Projects", url: "/projects" },
    { name: "Insurance", url: "/insurance" },
    { name: "Learning", url: "/learning" },
    { name: "Blog", url: "/blog" },
    { name: "Contact", url: "/contact" },
];

const currentPath = Astro.url.pathname;

// A quick helper function to strip trailing slashes so comparisons always match
const clean = (path: string) => path.replace(/\/$/, "") || "/";

// 1. Structural Check: Is the user currently inside the Bengali directory?
const isBengali = currentPath.startsWith("/bn") || currentPath.includes("/bn/");

// 2. Dynamic Link Localizer: Smart routes depending on current location
const getLocalizedUrl = (url: string) => {
    if (!isBengali) return url;
    if (url === "/") return "/bn"; // Bengali Home base
    return `/bn${url}`; // Prefixes /bn onto other sub-pages
};

// 3. Perfect Language Switch Matrix: Evaluates current path to route to cross-language twin
// Example: Clicking the pill on /bn/about takes you directly to /about, and vice-versa!
const toggleUrl = isBengali
    ? currentPath.replace(/^\/bn/, "") || "/"
    : currentPath === "/"
      ? "/bn"
      : `/bn${currentPath}`;

const toggleLabel = isBengali ? "English" : "বাংলা";
const toggleTitle = isBengali ? "Switch to English" : "বাংলা সংস্করণ";
---

<!-- Header -->
<header class="site-header">
    <div class="container">
        <div class="logo">
            <h1>Santanu's Space</h1>
            <p>Technology • Insurance • Learning</p>
        </div>
    </div>

    <nav>
        {
            navItems.map((item) => {
                // Compute the proper localized path based on environment context
                const localizedUrl = getLocalizedUrl(item.url);

                // Match active status against the computed localized path
                const isActive =
                    clean(currentPath) === clean(localizedUrl) ||
                    (item.name === "Insurance" &&
                        currentPath.includes("insurance")) ||
                    (item.name === "Blog" && currentPath.includes("blog"));

                // Handle Insurance dropdown configuration cleanly without repeating links
                if (item.name === "Insurance") {
                    return (
                        <div class="dropdown">
                            <a
                                href={localizedUrl}
                                class={isActive ? "active" : ""}
                            >
                                {item.name} ▾
                            </a>
                            <div class="dropdown-content">
                                <a href={getLocalizedUrl("/health-insurance")}>
                                    Health Insurance
                                </a>
                                <a href={getLocalizedUrl("/life-insurance")}>
                                    Life Insurance
                                </a>
                            </div>
                        </div>
                    );
                }

                // Standard Navigation Output
                return (
                    <a href={localizedUrl} class={isActive ? "active" : ""}>
                        {item.name}
                    </a>
                );
            })
        }

        <!-- Intelligent Global Toggle Pill -->
        <a href={toggleUrl} class="lang-toggle" title={toggleTitle}
            >{toggleLabel}</a
        >
    </nav>
</header>
