---
// src/components/Header.astro

const navItems = [
    { name: 'Home', url: '/' },
    { name: 'About', url: '/about' },
    { name: 'Projects', url: '/projects' },
    { name: 'Insurance', url: '/insurance' },
    { name: 'Learning', url: '/learning' },
    { name: 'Contact', url: '/contact' }
];

const currentPath = Astro.url.pathname;

// A quick helper function to strip trailing slashes so comparisons always match
const clean = (path: string) => path.replace(/\/$/, '') || '/';
---

<!-- Header -->
<header>
    <div class="container">
        <div class="logo">
            <h1>Santanu's Space</h1>
            <p>Technology • Insurance • Learning</p>
        </div>
    </div>
</header>

<nav>
    {navItems.map((item) => (
        <a 
            href={item.url} 
            /* We use the clean() helper here to compare both paths safely */
            class={clean(currentPath) === clean(item.url) ? 'active' : ''}
        >
            {item.name}
        </a>
    ))}
    
    <a href="/bn" class="lang-toggle" title="বাংলা সংস্করণ">বাংলা</a>
</nav>