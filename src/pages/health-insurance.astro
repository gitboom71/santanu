---
// src/pages/health-insurance.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
// Link the shared master styles
import '../styles/insurance.css';
import InsuranceNav from '../components/InsuranceNav.astro';

const pageTitle = "Health Insurance Awareness | The Santanu Initiative";
const pageDescription =
  "Master health insurance fundamentals, Mediclaim choices, and cashless network tracking.";

// Core Concepts Data Array
const coreConcepts = [
  {
    title: "Cashless Network",
    desc: "Hospitals partnered with your insurer where treatments are settled directly without you paying upfront out of pocket.",
  },
  {
    title: "Waiting Period",
    desc: "The time frame (typically 2-4 years for pre-existing diseases) before specific treatments are covered by the policy.",
  },
  {
    title: "Co-Payment",
    desc: "A fixed percentage of the total medical bill (e.g., 10% or 20%) that you agree to pay yourself during a claim settlement.",
  },
];

// Comparison Table Data Array
const comparisonRows = [
  {
    feature: "Coverage Target",
    individual: "One specific insured person",
    floater: "Shared pool among the entire family",
  },
  {
    feature: "Premium Cost",
    individual: "Higher if buying separately for each member",
    floater: "Highly economical for younger families",
  },
  {
    feature: "Sum Insured Reset",
    individual: "Belongs entirely to that individual",
    floater: "If one member utilizes it, the pool reduces for others",
  },
];

// FAQ Data Array
const faqs = [
  {
    question: "What is a Deductible?",
    answer:
      "A deductible is a fixed amount you must pay toward medical expenses each year before your insurance company begins footing the bills.",
  },
  {
    question: "Does health insurance cover maternity from day one?",
    answer:
      "Generally no. Most health insurance products enforce a strict waiting period ranging between 9 months to 4 years for maternity benefits.",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Header />

    <InsuranceNav />

  <!-- ========================== CORE CONCEPTS ========================== -->
  <section id="concepts" class="section">
    <div class="container">
      <span class="section-tag">Fundamentals</span>
      <h2>Understanding Medical Coverage</h2>
      <p class="section-intro">
        Health insurance protects your savings from unexpected medical
        emergencies. Here are the core pillars you must understand before buying
        a policy.
      </p>

      <div class="cards">
        {
          coreConcepts.map((concept) => (
            <div class="card">
              <h3>{concept.title}</h3>
              <p>{concept.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========================== PLAN COMPARISON ========================== -->
  <section id="comparison" class="section light">
    <div class="container">
      <h2>Individual Mediclaim vs. Family Floater</h2>
      <div class="comparison-table">
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Feature</th>
                <th>Individual Policy</th>
                <th>Family Floater Policy</th>
              </tr>
            </thead>
            <tbody>
              {
                comparisonRows.map((row) => (
                  <tr>
                    <td>
                      <strong>{row.feature}</strong>
                    </td>
                    <td>{row.individual}</td>
                    <td>{row.floater}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================== HEALTH FAQS ========================== -->
  <section id="faq" class="section">
    <div class="container">
      <h2>Health Insurance FAQs</h2>
      <div class="faq">
        {
          faqs.map((faq) => (
            <div class="faq-block">
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<!-- Linking your global script file from the public directory -->
<script is:inline src="/js/insurance.js"></script>


