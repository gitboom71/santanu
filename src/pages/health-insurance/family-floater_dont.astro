---
/**
 * ============================================================================
 * FILE: src/pages/health-insurance/family-floater.astro
 * PAGE: Family Floater Health Insurance Spoke Page (/health-insurance/family-floater)
 * SITE: Santanu's Space
 * VERSION: 1.0.0
 * 
 * DESCRIPTION:
 * Detailed guide on Family Floater health plans, sum insured allocation, 
 * room rent limits, and restoration benefits.
 * 
 * DEPENDENCIES:
 * - src/layouts/BaseLayout.astro
 * - src/components/Header.astro
 * - src/components/Footer.astro
 * ============================================================================
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Family Floater Health Insurance Guide";
const pageDescription = "Learn how family floater health plans cover your entire family under a single umbrella policy with shared sum insured.";
---

<BaseLayout title={pageTitle} description={pageDescription} lang="en">
  <Header />

  <main>
    <!-- HERO SECTION -->
    <section style="background-color: #f8fafd; padding: 3.5rem 1rem; border-bottom: 1px solid #e2e8f0;">
      <div style="max-width: 850px; margin: 0 auto; text-align: center;">
        <a href="/health-insurance" style="color: #0b3d91; font-weight: bold; text-decoration: none; font-size: 0.9rem;">← Back to Health Insurance Hub</a>
        <h1 style="font-size: 2.4rem; color: #0b3d91; margin: 1rem 0 0.5rem 0;">
          Family Floater Health Insurance
        </h1>
        <p style="color: #4a5568; font-size: 1.15rem; line-height: 1.6;">
          One unified medical policy to cover yourself, your spouse, and your children.
        </p>
      </div>
    </section>

    <!-- MAIN ARTICLE CONTENT -->
    <section style="padding: 3rem 1rem;">
      <div style="max-width: 800px; margin: 0 auto; color: #2d3748; line-height: 1.8;">
        
        <!-- CARD 1: WHAT IS A FAMILY FLOATER -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">1. How Does a Family Floater Work?</h2>
          <p>
            Unlike individual plans where each person has a dedicated limit, a Family Floater shares a single pool of coverage (e.g., ₹10 Lakhs or ₹25 Lakhs) across all covered family members. If one person falls ill, they can use up to the full limit. If another family member needs hospitalization later in the year, they can use whatever sum insured remains.
          </p>
        </div>

        <!-- CARD 2: KEY CLAUSES TO CHECK -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">2. Three Crucial Clauses to Look For</h2>
          <ul>
            <li><strong>Room Rent Capping:</strong> Choose policies with <em>No Room Rent Capping</em> or <em>Single Private A/C Room</em> coverage to prevent proportional deduction penalties on your entire bill.</li>
            <li><strong>Restoration Benefit (Refill):</strong> Automatically restores your sum insured by 100% if it gets exhausted by a hospitalization during the policy year.</li>
            <li><strong>Pre-Existing Disease (PED) Waiting Period:</strong> Look for policies with short waiting periods (1 to 2 years) for conditions like diabetes or hypertension.</li>
          </ul>
        </div>

        <!-- CARD 3: IDEAL COVER SIZE -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">3. Recommended Cover Size</h2>
          <p>
            For a family of 4 living in a metro or Tier-1 city, a base floater cover of <strong>₹10 Lakhs to ₹25 Lakhs</strong> is the recommended starting baseline to cushion against rising healthcare inflation.
          </p>
        </div>

        <!-- CTA BOX -->
        <div style="text-align: center; margin-top: 3rem; padding: 2rem; background: #0b3d91; color: #ffffff; border-radius: 8px;">
          <h3 style="margin-top: 0; color: #ffffff;">Evaluating Health Policies for Your Family?</h3>
          <p style="color: #e2e8f0; margin-bottom: 1.5rem;">Let's compare waiting periods and fine print together.</p>
          <a href="/contact" style="display: inline-block; background: #ffffff; color: #0b3d91; font-weight: bold; padding: 0.8rem 1.8rem; border-radius: 5px; text-decoration: none;">Request Advice →</a>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>