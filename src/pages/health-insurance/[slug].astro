---
/**
 * Path: src/pages/health-insurance/[slug].astro
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const allHealthPosts = await getCollection('health');

  const uniqueSlugs = [
    ...new Set(allHealthPosts.map(p => p.id.replace(/\.md$/, '').replace(/-(en|bn)$/, '')))
  ];

  return uniqueSlugs.map(slug => {
    // Look for English version first
    const enPost = allHealthPosts.find(p => p.id === `${slug}-en.md` || p.id === `${slug}-en` || p.id === `${slug}.md`);
    // Fallback to Bengali if English doesn't exist
    const bnPost = allHealthPosts.find(p => p.id === `${slug}-bn.md` || p.id === `${slug}-bn`);

    return {
      params: { slug },
      props: { post: enPost || bnPost },
    };
  });
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} lang="en">
  <Header />

  <main style="max-width: 800px; margin: 3rem auto; padding: 0 1.25rem;">
    <article class="markdown-body">
      <h1>{post.data.title}</h1>
      <Content />
    </article>
  </main>

  <Footer />
</BaseLayout>