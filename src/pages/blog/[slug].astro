---
/**
 * Dynamic English Blog Post Template
 * Path: /blog/[slug]
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts
    .filter(post => post.data.lang === 'en' || !post.data.lang)
    .map(post => {
      const cleanSlug = post.id
        .replace(/\.md$/, '')
        .replace(/-en$/, '');

      return {
        params: { slug: cleanSlug },
        props: { post },
      };
    });
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={post.data.title} description={post.data.description} lang="en">
  <Header />

  <main class="article-container">
    <a href="/blog" class="back-link">&larr; Back to Blog</a>

    <article class="article-card">
      <header class="article-header">
        <span class="category-tag">Guide</span>
        <h1>{post.data.title}</h1>
        {post.data.description && <p class="article-subtitle">{post.data.description}</p>}
        
        <div class="meta-row">
          <div class="author-info">
            <div class="avatar">{post.data.author ? post.data.author.charAt(0) : 'S'}</div>
            <div>
              <span class="author-name">{post.data.author || 'Santanu Mukherjee'}</span>
              <span class="pub-date">Published on {formattedDate}</span>
            </div>
          </div>
        </div>
      </header>

      <!-- 👇 MARKDOWN CONTAINER FOR GLOBAL SPACING 👇 -->
      <div class="markdown-body">
        <Content />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .article-container {
    max-width: 800px;
    margin: 3rem auto;
    padding: 0 1.25rem;
  }
  .back-link {
    display: inline-block;
    color: #0b3d91;
    font-weight: 600;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  /* Article Card Styling */
  .article-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 3rem 2.5rem;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
  }
  
  .category-tag {
    background: #e0f2fe;
    color: #0369a1;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .article-header h1 {
    font-size: 2.25rem;
    color: #0f172a;
    line-height: 1.3;
    margin: 0 0 0.75rem 0;
    font-weight: 800;
  }
  .article-subtitle {
    font-size: 1.15rem;
    color: #475569;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .meta-row {
    border-top: 1px solid #f1f5f9;
    border-bottom: 1px solid #f1f5f9;
    padding: 1rem 0;
    margin-bottom: 2.5rem;
  }
  .author-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .avatar {
    width: 42px;
    height: 42px;
    background: #0b3d91;
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: justify-content;
    justify-content: center;
    font-weight: bold;
    font-size: 1.1rem;
  }
  .author-name {
    display: block;
    font-weight: 700;
    color: #1e293b;
    font-size: 0.95rem;
  }
  .pub-date {
    display: block;
    color: #64748b;
    font-size: 0.85rem;
  }
</style>