---
/**
 * ============================================================================
 * FILE: src/pages/bn/health-insurance/family-floater.astro
 * PAGE: Bengali Family Floater Health Insurance Spoke Page (/bn/health-insurance/family-floater)
 * SITE: Santanu's Space
 * VERSION: 1.0.0
 * 
 * DESCRIPTION:
 * Detailed Bengali guide on Family Floater health insurance by Santanu Mukherjee (শান্তনু মুখার্জ্জী).
 * 
 * DEPENDENCIES:
 * - src/layouts/BaseLayout.astro
 * - src/components/Header.astro
 * - src/components/Footer.astro
 * ============================================================================
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const pageTitle = "ফ্যামিলি ফ্লোটার হেলথ ইনসিওরেন্স গাইড";
const pageDescription = "একটি মাত্র পলিসিতে পুরো পরিবারের স্বাস্থ্য সুরক্ষা নিশ্চিত করার গাইডলাইন — শান্তনু মুখার্জ্জী।";
---

<BaseLayout title={pageTitle} description={pageDescription} lang="bn">
  <Header />

  <main>
    <!-- HERO SECTION -->
    <section style="background-color: #f8fafd; padding: 3.5rem 1rem; border-bottom: 1px solid #e2e8f0;">
      <div style="max-width: 850px; margin: 0 auto; text-align: center;">
        <a href="/bn/health-insurance" style="color: #0b3d91; font-weight: bold; text-decoration: none; font-size: 0.9rem;">← স্বাস্থ্য বীমা মূল পেজে ফিরে যান</a>
        <h1 style="font-size: 2.4rem; color: #0b3d91; margin: 1rem 0 0.5rem 0;">
          ফ্যামিলি ফ্লোটার স্বাস্থ্য বীমা (Family Floater)
        </h1>
        <p style="color: #4a5568; font-size: 1.15rem; line-height: 1.6;">
          একটি মাত্র পলিসিতে নিজে, জীবনসঙ্গী ও সন্তানের জন্য একত্রিত স্বাস্থ্য সুরক্ষা — শান্তনু মুখার্জ্জী।
        </p>
      </div>
    </section>

    <!-- MAIN ARTICLE CONTENT -->
    <section style="padding: 3rem 1rem;">
      <div style="max-width: 800px; margin: 0 auto; color: #2d3748; line-height: 1.8;">
        
        <!-- CARD 1: WHAT IS A FAMILY FLOATER -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">১. ফ্যামিলি ফ্লোটার পলিসি কীভাবে কাজ করে?</h2>
          <p>
            পৃথক আলাদা পলিসির পরিবর্তে ফ্যামিলি ফ্লোটার পলিসিতে পুরো পরিবারের জন্য একটি নির্দিষ্ট অঙ্কের বিমা রাশি (যেমন ১০ লাখ বা ২৫ লাখ টাকা) বরাদ্দ থাকে। পরিবারের যেকোনো সদস্য অসুস্থ হলে এই সম্পূর্ণ বিমা রাশি ব্যবহার করতে পারেন।
          </p>
        </div>

        <!-- CARD 2: KEY CLAUSES TO CHECK -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">২. পলিসি কেনার আগে গুরুত্বপূর্ণ ৩টি বিষয়</h2>
          <ul>
            <li><strong>রুম রেন্ট ক্যাপ (Room Rent Limit):</strong> কোনো নির্দিষ্ট রুম রেন্টের সীমা (যেমন ১%) না থাকা পলিসি বেছে নেওয়া উচিত, যাতে হাসপাতালের অন্যান্য বিলেও অতিরিক্ত চার্জ না কাটা যায়।</li>
            <li><strong>রিস্টোরেশন বেনিফিট (Restoration):</strong> কোনো এক বছরে মূল বিমা রাশি শেষ হয়ে গেলে কোম্পানি আবার স্বয়ংক্রিয়ভাবে সমপরিমাণ টাকা পুনর্নবীকরণ করে দেয়।</li>
            <li><strong>ওয়েটিং পিরিয়ড (Waiting Period):</strong> উচ্চ রক্তচাপ বা ডায়াবেটিসের মতো পূর্বসূরী রোগের ক্ষেত্রে কতদিন অপেক্ষা করতে হবে তা আগে জেনে নেওয়া প্রয়োজন (১-২ বছর আদর্শ)।</li>
          </ul>
        </div>

        <!-- CARD 3: IDEAL COVER SIZE -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">৩. কত টাকার কভার নেওয়া উচিত?</h2>
          <p>
            বর্তমানে চিকিৎসা খরচের বৃদ্ধির কথা মাথায় রেখে চারজনের একটি পরিবারের জন্য অন্তত <strong>১০ লাখ থেকে ২৫ লাখ টাকার</strong> বেস ফ্লোটার পলিসি থাকা অত্যন্ত জরুরি।
          </p>
        </div>

        <!-- CTA BOX -->
        <div style="text-align: center; margin-top: 3rem; padding: 2rem; background: #0b3d91; color: #ffffff; border-radius: 8px;">
          <h3 style="margin-top: 0; color: #ffffff;">পরিবারের জন্য সঠিক হেলথ প্ল্যান বাছাই করতে চান?</h3>
          <p style="color: #e2e8f0; margin-bottom: 1.5rem;">ওয়েটিং পিরিয়ড এবং অন্যান্য শর্তাবলী সম্পর্কে নিরপেক্ষ পরামর্শ নিন।</p>
          <a href="/bn/contact" style="display: inline-block; background: #ffffff; color: #0b3d91; font-weight: bold; padding: 0.8rem 1.8rem; border-radius: 5px; text-decoration: none;">যোগাযোগ করুন →</a>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>