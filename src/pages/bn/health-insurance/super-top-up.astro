---
/**
 * ============================================================================
 * FILE: src/pages/bn/health-insurance/super-top-up.astro
 * PAGE: Bengali Super Top-Up Health Insurance Spoke Page (/bn/health-insurance/super-top-up)
 * SITE: Santanu's Space
 * VERSION: 1.0.0
 * 
 * DESCRIPTION:
 * Detailed Bengali guide on Super Top-Up plans by Santanu Mukherjee (শান্তনু মুখার্জ্জী).
 * 
 * DEPENDENCIES:
 * - src/layouts/BaseLayout.astro
 * - src/components/Header.astro
 * - src/components/Footer.astro
 * ============================================================================
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const pageTitle = "সুপার টপ-আপ হেলথ ইনসিওরেন্স গাইড";
const pageDescription = "কম খরচে কভার ৫০ লাখ বা ১ কোটি টাকায় উন্নীত করার কৌশল — শান্তনু মুখার্জ্জী।";
---

<BaseLayout title={pageTitle} description={pageDescription} lang="bn">
  <Header />

  <main>
    <!-- HERO SECTION -->
    <section style="background-color: #f8fafd; padding: 3.5rem 1rem; border-bottom: 1px solid #e2e8f0;">
      <div style="max-width: 850px; margin: 0 auto; text-align: center;">
        <a href="/bn/health-insurance" style="color: #0b3d91; font-weight: bold; text-decoration: none; font-size: 0.9rem;">← স্বাস্থ্য বীমা মূল পেজে ফিরে যান</a>
        <h1 style="font-size: 2.4rem; color: #0b3d91; margin: 1rem 0 0.5rem 0;">
          সুপার টপ-আপ স্বাস্থ্য বীমা (Super Top-Up)
        </h1>
        <p style="color: #4a5568; font-size: 1.15rem; line-height: 1.6;">
          অল্প প্রিমিয়ামে আপনার হেলথ কভার ৫০ লাখ বা ১ কোটি টাকায় বাড়ানোর স্মার্ট কৌশল — শান্তনু মুখার্জ্জী।
        </p>
      </div>
    </section>

    <!-- MAIN ARTICLE CONTENT -->
    <section style="padding: 3rem 1rem;">
      <div style="max-width: 800px; margin: 0 auto; color: #2d3748; line-height: 1.8;">
        
        <!-- CARD 1: WHAT IS A SUPER TOP-UP -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">১. সুপার টপ-আপ কী?</h2>
          <p>
            সুপার টপ-আপ হলো অতিরিক্ত সুরক্ষাবলয়। হাসপাতালে চিকিৎসার খরচ একটি নির্দিষ্ট সীমা (যাকে Deductible বলা হয়) পার হলেই এই পলিসি কার্যকর হয়। যেহেতু প্রাথমিক খরচটি বেস পলিসি মেটায়, তাই ইন্স্যুরেন্স কোম্পানিগুলো সুপার টপ-আপে খুব কম প্রিমিয়ামে বিশাল টাকার কভার প্রদান করে।
          </p>
        </div>

        <!-- CARD 2: TOP-UP vs SUPER TOP-UP -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">২. নরমাল টপ-আপ বনাম সুপার টপ-আপ</h2>
          <ul>
            <li><strong>নরমাল টপ-আপ:</strong> বছরের <em>প্রতিটি আলাদা হাসপাতালে ভর্তির ক্ষেত্রে</em> আলাদাভাবে ডিডাক্টেবল সীমা হিসাব করা হয়।</li>
            <li><strong>সুপার টপ-আপ:</strong> সারা বছরে মোট চিকিৎসার <em>একত্রিত বিলের ওপর</em> ডিডাক্টেবল সীমা হিসাব করা হয়, যা গ্রাহকের জন্য সবচেয়ে লাভজনক।</li>
          </ul>
        </div>

        <!-- CARD 3: HOW TO STRUCTURE -->
        <div style="background: #ffffff; padding: 2rem; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 2rem;">
          <h2 style="color: #0b3d91; font-size: 1.5rem; margin-top: 0;">৩. সেরা স্ট্র্যাটেজি: বেস + সুপার টপ-আপ</h2>
          <p>
            একটি <strong>৫ বা ১০ লাখ টাকার বেস পলিসির</strong> সাথে <strong>৪০ বা ৯০ লাখ টাকার সুপার টপ-আপ</strong> যোগ করুন। এতে সরাসরি ১ কোটি টাকার মূল পলিসি কেনার চেয়ে প্রায় ৫০-৬০% পর্যন্ত প্রিমিয়াম বাঁচানো সম্ভব।
          </p>
        </div>

        <!-- CTA BOX -->
        <div style="text-align: center; margin-top: 3rem; padding: 2rem; background: #0b3d91; color: #ffffff; border-radius: 8px;">
          <h3 style="margin-top: 0; color: #ffffff;">কম খরচে স্বাস্থ্য সুরক্ষা বাড়াতে চান?</h3>
          <p style="color: #e2e8f0; margin-bottom: 1.5rem;">আপনার বর্তমান পলিসির ওপর ভিত্তি করে সেরা সুপার টপ-আপ বেছে নিন।</p>
          <a href="/bn/contact" style="display: inline-block; background: #ffffff; color: #0b3d91; font-weight: bold; padding: 0.8rem 1.8rem; border-radius: 5px; text-decoration: none;">যোগাযোগ করুন →</a>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>