---
// src/layouts/MarkdownLayout.astro
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Astro automatically collects Markdown top-matter settings inside Astro.props.frontmatter
const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title}>
  <Header />

  <!-- Wraps your Markdown text inside your native global style.css layout tools -->
  <main class="section light">
    <div class="container content-markdown-area">
      <slot /> 
    </div>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  /* Quick cosmetic adjustments specifically for Markdown elements */
  .content-markdown-area h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    color: #0b3d91;
  }
  .content-markdown-area h3 {
    margin-top: 2rem;
    margin-bottom: 0.8rem;
    color: #08306b;
  }
  .content-markdown-area ul {
    margin-left: 2rem;
    margin-bottom: 1.5rem;
  }
  .content-markdown-area li {
    margin-bottom: 0.5rem;
  }
</style>