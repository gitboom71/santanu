---
// src/layouts/BaseLayout.astro
import { ClientRouter } from 'astro:transitions';
import { SITE } from '../config/site';
import '../styles/style.css'; 

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const { 
  title, 
  description = SITE.description, 
  lang = SITE.defaultLanguage 
} = Astro.props;

// Formats title nicely: e.g. "About | Santanu's Space", or falls back to "Santanu's Space" if title isn't provided
const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title;
---

<html lang={lang}>
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        
        <!-- Author & Description from SITE config -->
        <meta name="author" content={SITE.author} />
        <meta name="description" content={description} />
        
        <title>{pageTitle}</title>

        <!-- ASTRO VIEW TRANSITIONS (Gives the slick "Same-Frame" smooth navigation feel) -->
        <ClientRouter />
    </head>
    <body>
        
        <!-- Everything from your pages will be injected here -->
        <slot />

    </body>
</html>